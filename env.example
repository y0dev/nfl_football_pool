# Site URL (required for Open Graph / social share metadata AND email links)
NEXT_PUBLIC_SITE_URL=https://yourdomain.com
NEXT_PUBLIC_APP_URL=https://yourdomain.com

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# NFL API Configuration (Optional - will use mock data if not set)
API_SPORTS_KEY=your_api_sports_key

# Email Configuration — Hostinger SMTP (noreply@sundayhuddle.net)
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USER=noreply@sundayhuddle.net
SMTP_PASS=your_hostinger_email_password
SMTP_FROM=Sunday Huddle <noreply@sundayhuddle.net>

# Admin Notification Email (receives admin creation alerts)
ADMIN_NOTIFICATION_EMAIL=your_email@yourdomain.com