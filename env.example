# Site URL (required for Open Graph / social share metadata AND email links)
NEXT_PUBLIC_SITE_URL=https://yourdomain.com
NEXT_PUBLIC_APP_URL=https://yourdomain.com

# Supabase Configuration
# NEXT_PUBLIC_ vars are inlined into the browser bundle at build time (visible to all users)
# Non-NEXT_PUBLIC_ vars are server-only (Node.js only — never sent to the browser)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
# Primary: server-only service key (never exposed to browser)
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
# Fallback: set to same value — required for client components that use the service client directly
# TODO: refactor client components to use server actions and remove this fallback
NEXT_PUBLIC_SUPABASE_SERVICE_KEY=your_supabase_service_role_key_here

# NFL API Configuration (Optional - will use mock data if not set)
API_SPORTS_KEY=your_api_sports_key

# Email Configuration — Hostinger SMTP (noreply@sundayhuddle.net)
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USER=noreply@sundayhuddle.net
SMTP_PASS=your_hostinger_email_password
SMTP_FROM=Sunday Huddle <noreply@sundayhuddle.net>

# Admin Notification Email (receives admin creation alerts)
ADMIN_NOTIFICATION_EMAIL=your_email@yourdomain.com

# Cron authentication — required in production for /api/email/urgent-reminders
# (send the same value as an x-cron-secret header or Bearer token from your
# cron service). Unset = the route is disabled in production.
# CRON_SECRET=some-long-random-string

# ── Billing (Stripe) ──────────────────────────────────────────────
# Pricing visibility: unset = visible in dev, hidden in production.
# Set to true to unhide /pricing, pricing nav links, and dollar amounts
# on /upgrade once Stripe is live. Plan/pool/member limits are enforced
# regardless of this flag.
# NEXT_PUBLIC_ENABLE_PRICING=true

# Sales — list prices are $50/season (Standard) and $15/pool/season (add-on),
# defined in src/lib/pricing.ts. Set a sale price below the list price to show
# it struck-through with a sale badge; unset to end the sale. Build-time vars —
# redeploy after changing.
# NEXT_PUBLIC_SALE_STANDARD=30
# NEXT_PUBLIC_SALE_ADDON=10
# NEXT_PUBLIC_SALE_LABEL=Kickoff Sale

# Stripe keys — leave unset until the Stripe account exists. All billing
# routes return 503 while unset. See docs/stripe-billing-setup.md for the
# full go-live checklist (products, webhook, DB migration).
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_STANDARD=price_...        # Standard plan, one-time, $30/season
# STRIPE_PRICE_ADDON_POOL=price_...      # Add-on pool, one-time, $15/pool/season